# MACIE Core Shell environment template
# Copy to .env and fill in. Never commit .env.

# Model API keys (Core Shell only — engine adapters read these at runtime)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cloudflare Access — Core Shell route protection
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

# Allowlist (Phase 1: Pete + Pete Jr. only)
ALLOWED_ADMIN_EMAILS=
ALLOWED_TESTER_EMAILS=

# Audit log destination (append-only)
AUDIT_LOG_PATH=./audit/macie.log

# Environment marker
MACIE_ENV=development
